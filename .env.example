MC_VERSION=1.20.1

VELOCITY_PORT=25565
VELOCITY_MEMORY=512m

# Must match velocity/forwarding.secret value.
# Same secret is used by FabricProxy-Lite on all backend Fabric servers.
# Change this secret only in .env (scripts will sync velocity/forwarding.secret).
VELOCITY_FORWARDING_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
FABRIC_PROXY_HACK_ONLINE_MODE=true
FABRIC_PROXY_HACK_EARLY_SEND=false
FABRIC_PROXY_HACK_MESSAGE_CHAIN=true
FABRIC_PROXY_DISCONNECT_MESSAGE="This server requires you to connect with Velocity."

# Backend servers behind Velocity must stay in offline mode.
# Velocity performs player auth/identity checks, not backend Fabric servers.
MC_ONLINE_MODE=false
MC_ENFORCE_SECURE_PROFILE=false
MC_SERVER_PORT=25565
# Must be empty for backend containers behind proxy; do not set localhost/127.0.0.1/container IP.
MC_SERVER_IP=
MC_PREVENT_PROXY_CONNECTIONS=false
MC_ENABLE_RCON=true
MC_RCON_PORT=25575
# server.properties is managed in data/<server>/server.properties (root of data dir), not data/<server>/config.

HUB_MEMORY=1G
ISLAND_MEMORY=1500M

HUB_VIEW_DISTANCE=4
HUB_SIMULATION_DISTANCE=3

VIEW_DISTANCE=5
SIMULATION_DISTANCE=3
MAX_PLAYERS=50

PUBLIC_DOMAIN=gerbarium.duckdns.org

STATUS_DOMAIN=status.gerbarium.duckdns.org

MAP1_DOMAIN=map1.gerbarium.duckdns.org
MAP2_DOMAIN=map2.gerbarium.duckdns.org
MAP3_DOMAIN=map3.gerbarium.duckdns.org
MAP4_DOMAIN=map4.gerbarium.duckdns.org

MAP1_PORT=8153
MAP2_PORT=8154
MAP3_PORT=8155
MAP4_PORT=8156

VELOCITY_WEB_API_PORT=25576

PORTAINER_BIND_IP=127.0.0.1
PORTAINER_BIND_PORT=9443

# Packwiz backend server pack (Fabric backend services only).
# Velocity does not use this value.
# Launcher/client modpack updates are managed in a separate repository.
# Server pack metadata is hosted on GitHub Pages.
SERVER_PACKWIZ_URL=https://xielain-art.github.io/minecraft-server/packs/server/pack.toml

# true: packwiz is primary backend mod source.
PACKWIZ_SERVER_MODE=true

# false: keep shared/mods and servers/<server>/mods as preserved manual layer only.
# true: copy manual override jars on top without deleting packwiz-managed mods.
ENABLE_MANUAL_MOD_OVERRIDES=false
VELOCITY_VERSION=3.5.0